{
  "expo": {
    "name": "Kōra",
    "slug": "kora",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "kora",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#15140F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#15140F"
        }
      ],
      "expo-sqlite",
      "expo-asset",
      [
        "expo-image-picker",
        {
          "photosPermission": "Kōra necesita acceso a tus fotos para poder elegir una portada personalizada para tus juegos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
